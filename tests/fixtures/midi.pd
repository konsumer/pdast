#N canvas 0 50 450 300 12;
#X obj 30 30 notein;
#X obj 30 60 mtof;
#X obj 30 90 osc~;
#X obj 100 60 / 127;
#X obj 30 130 *~;
#X obj 30 170 dac~;
#X text 10 10 MIDI note-in: pitch to frequency, velocity to amplitude;
